									detail: {
										accepted_cookies: level
									}
								});
								document.dispatchEvent(customEvent);
							}, 300);
                        },
						onAccept: function(cookies) {
							setTimeout(function() {
								const level = cookies.level;
								const customEvent = new CustomEvent('cookieconsent_accepted', {
									detail: {
										accepted_cookies: level
									}
								});
								document.dispatchEvent(customEvent);
							}, 300);
						},
						gui_options: {
							consent_modal: {
								layout: 'bar',
